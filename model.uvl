namespace SchedulingManagementSystem

features
	SchedulingManagementSystem
		mandatory
			TaskManagement
		optional
			Project
				optional
					ProgrammingProject
			Label
			BeritaBoard
			Reminder
			MeetingManagement
				optional
					ProjectMeeting

constraints
	Project => Label
	Project | Label | BeritaBoard
	!(BeritaBoard & Reminder)
	!(Label & BeritaBoard)
	ProjectMeeting => Project

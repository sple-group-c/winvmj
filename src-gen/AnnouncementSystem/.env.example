# WinVMJ Environment Configuration
# Product: AnnouncementSystem
# Generated by WinVMJ Composer
#
# @prices Annotations (for Prices Deployment Platform):
#   @prices-keep     - Keep value as-is (explicit)
#   @prices-ignore   - Skip, don't include in .env
#   @prices-override - Use provided value or keep default
#   @prices-autogen  - Auto-generate random value
#   (no annotation)  - Default: keep as-is

# ============================================
# Backend Server Configuration
# ============================================
# Backend server host address
AMANAH_HOST_BE=0.0.0.0

# Backend server port number
AMANAH_PORT_BE=7776

# ============================================
# Database Configuration
# ============================================
# PostgreSQL connection URL (for Docker: use postgres as hostname)
AMANAH_DB_URL=jdbc:postgresql://postgres:5432/announcementsystem

# Database username
# @prices-autogen
AMANAH_DB_USERNAME=postgres

# Database password
# @prices-autogen
AMANAH_DB_PASSWORD=postgres123

# ============================================
# Docker Port Mappings (HOST:CONTAINER)
# ============================================
# Note: Container internal ports are fixed (7776, 9464)
# These variables control which HOST ports map to them

# Backend server host port (maps to container:7776)
# @prices-ignore
HOST_PORT_BE=7776

# PostgreSQL host port (maps to container:5432)
# @prices-ignore
HOST_PORT_POSTGRES=5432


# ============================================
# Usage Instructions
# ============================================
# For Docker Compose:
#   1. Copy this file to .env
#   2. Modify values as needed
#   3. Run: docker-compose up -d
#
# For Gradle (local development):
#   1. Copy to gradle.properties
#   2. Add prefix "systemProp." to each variable
#      Example: systemProp.AMANAH_DB_URL=jdbc:postgresql://localhost:5432/announcementsystem
#
# For System Environment (Windows PowerShell):
#   $env:AMANAH_DB_URL="jdbc:postgresql://localhost:5432/announcementsystem"
#
# For Prices Deployment Platform:
#   Annotations above each variable tell the platform how to handle them.
